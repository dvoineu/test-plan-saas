{
  "name": "test-plan-manager",
  "version": "0.1.0",
  "description": "Test Management Desktop Application",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "build:mac": "npm run build:electron && electron-builder --mac",
    "build:mac-store": "npm run build:electron && electron-builder --mac mas",
    "build:win": "npm run build:electron && electron-builder --win",
    "build:all": "npm run build:electron && electron-builder -mwl",
    "start": "next start",
    "start:electron": "electron .",
    "lint": "eslint .",
    "clean": "next clean",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@neondatabase/serverless": "^1.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@tanstack/react-query": "^5.90.21",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.3.1",
    "wait-on": "^8.0.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}