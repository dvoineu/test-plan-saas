# Database Configuration
# Options: 'sqlite' | 'postgres'
DB_PROVIDER=postgres

# PostgreSQL Connection String
DATABASE_URL="postgres://postgres:password@localhost:5432/qa_hub?schema=public"

# File Storage path (absolute or relative)
FILES_PATH="./public/uploads"

# AI Configuration
# Options: 'gemini' | 'ollama' | 'openai'
LLM_PROVIDER=gemini
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=http://localhost:11434/api/generate  # Un-comment for Ollama

# Next.js Port and URLs
PORT=3000
APP_URL=http://localhost:3000
